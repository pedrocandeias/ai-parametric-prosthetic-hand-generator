# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# Required: JWT secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-me-to-a-random-256-bit-secret

# AI Provider API Keys (server-side only — never expose these to clients)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Server
PORT=3000
NODE_ENV=development
